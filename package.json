{
  "name": "portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://Seng-Mouyheang.github.io/portfolio",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "prettier --write . && prettier --check . && eslint .",
    "preview": "vite preview",
    "predeploy": "pnpm build",
    "deploy": "gh-pages -d dist",
    "format": "prettier --write .",
    "spellcheck": "cspell '**/*.{ts,tsx,js,jsx,json,css,html}' --no-progress",
    "spellcheck:fix": "cspell --fix '**/*.{ts,tsx,js,jsx,json,css,html}'",
    "spellcheck:strict": "cspell \"**/*.{js,ts,jsx,tsx,md,json}\" --no-progress --fail-fast"
  },
  "dependencies": {
    "i18next": "^25.7.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.1",
    "react-icons": "^5.5.0",
    "react-router": "^7.11.0",
    "typewriter-effect": "^2.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "cspell": "^9.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "lefthook": "^2.1.4",
    "postcss": "^8.5.6",
    "prettier": "3.8.1",
    "tailwindcss": "^4.1.18",
    "vite": "^7.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  }
}
